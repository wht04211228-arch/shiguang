# Supabase Dashboard → Connect
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Server only. Prefer the new secret key; legacy service role is also supported.
SUPABASE_SECRET_KEY=sb_secret_YOUR_SERVER_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LEGACY_SERVICE_ROLE_KEY

# Generate with: openssl rand -base64 48
CARD_ACCESS_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Manual payment review. Prefer private paths in the Supabase merchant-assets bucket.
MANUAL_WECHAT_QR_PATH=wechat.png
MANUAL_ALIPAY_QR_PATH=alipay.png
# Optional fallback HTTPS URLs. Leave blank when private paths are configured.
MANUAL_WECHAT_QR_URL=
MANUAL_ALIPAY_QR_URL=
CUSTOMER_SERVICE_CONTACT=微信：your-wechat-id
# Optional multiline instructions; each line becomes one item on the payment page.
MANUAL_PAYMENT_INSTRUCTIONS=付款时请备注订单号后8位\n付款后上传清晰截图并填写完整交易单号\n管理员核对真实到账后开通制作权限

# DeepSeek AI copy assistant (optional; without it a deterministic local draft is returned)
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY
DEEPSEEK_MODEL=deepseek-v4-flash
# Usually keep the official base URL unchanged.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Email notifications (optional; without it notifications are written to server logs)
RESEND_API_KEY=re_YOUR_KEY
NOTIFICATION_FROM_EMAIL=拾光 <notifications@your-domain.com>

# Set true only for internal testing if cloud publishing should not require a paid order.
ALLOW_UNPAID_PUBLISH=false

# Comma-separated login emails allowed to access /admin
ADMIN_EMAILS=owner@example.com

# M6 operations and reminders
OPERATIONS_NOTIFICATION_EMAIL=owner@example.com
# Generate a long random value; Vercel Cron sends it as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-cron-secret
